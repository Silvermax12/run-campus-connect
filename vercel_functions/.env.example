# Environment Variables for RUN Campus Connect – Notification Gateway
#
# Set these in the Vercel dashboard under:
#   Project → Settings → Environment Variables
#
# NEVER commit real values of these variables to git.

# ── FIREBASE_SERVICE_ACCOUNT ─────────────────────────────────────────────────
# Full JSON content of your Firebase Service Account key.
#
# How to generate:
#   1. Go to Firebase Console → ⚙️ Project Settings → Service accounts
#   2. Click "Generate new private key"
#   3. Copy the entire content of the downloaded JSON file
#   4. Paste it as the value of this env var in Vercel (all on one line, or
#      Vercel will handle multi-line values correctly via the dashboard UI)
#
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"run-campus-connect","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@run-campus-connect.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
