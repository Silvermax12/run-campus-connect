rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the author
    function isAuthor(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAuthor(userId);
      
      // --- FIX #1: Friends Subcollection ---
      // We allow write if you are the profile owner OR if you are the friend.
      // This allows User A (friendId) to write to User B's (userId) collection.
      match /friends/{friendId} {
         allow read, write: if request.auth.uid == userId || request.auth.uid == friendId;
      }
    }

    // 2. Posts Collection
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorSnapshot.uid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorSnapshot.uid == request.auth.uid;

      match /likes/{userId} {
        allow read: if isSignedIn();
        allow write: if isAuthor(userId);
      }

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    // 3. Chats Collection
    match /chats/{chatId} {
      // --- FIX #2: Split Write into Update and Create ---
      
      // READ & UPDATE: Check EXISTING data (resource.data)
      // Allows reading and updating lastMessage if you are ALREADY in the chat
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // CREATE: Check NEW data (request.resource.data)
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the author
    function isAuthor(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAuthor(userId);
      
      // --- FIX #1: Friends Subcollection ---
      // We allow write if you are the profile owner OR if you are the friend.
      // This allows User A (friendId) to write to User B's (userId) collection.
      match /friends/{friendId} {
         allow read, write: if request.auth.uid == userId || request.auth.uid == friendId;
      }
    }

    // 2. Posts Collection
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorSnapshot.uid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorSnapshot.uid == request.auth.uid;

      match /likes/{userId} {
        allow read: if isSignedIn();
        allow write: if isAuthor(userId);
      }

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    // 3. Chats Collection
    match /chats/{chatId} {
      // --- FIX #2: Split Write into Update and Create ---
      
      // READ & UPDATE: Check EXISTING data (resource.data)
      // Allows reading and updating lastMessage if you are ALREADY in the chat
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // CREATE: Check NEW data (request.resource.data)
      // Allows creating a NEW chat if you include yourself in the participants
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;

      // Messages Subcollection
      match /messages/{messageId} {
        // We use get() to look up the parent Chat document participants
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // 4. Notifications Collection
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      // System/users can create notifications
      allow create: if isSignedIn();
      // Users can update their own notifications (e.g., mark as read)
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      // Users can delete their own notifications
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }
  }
}