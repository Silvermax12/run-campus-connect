rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isAuthor(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 1. USERS COLLECTION (Fixed for Badges) ---
    match /users/{userId} {
      allow read: if isSignedIn();
      
      // FIX: Allow update if it's YOU, OR if it's someone else ONLY touching the unread counter
      allow update: if isAuthor(userId) 
                    || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalUnreadMessages']));
      
      // Prevent strangers from creating/deleting your profile, only you can
      allow create, delete: if isAuthor(userId);

      // Friends Subcollection
      match /friends/{friendId} {
         allow read, write: if request.auth.uid == userId || request.auth.uid == friendId;
      }
    }

    // --- 2. POSTS COLLECTION ---
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorSnapshot.uid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorSnapshot.uid == request.auth.uid;

      match /likes/{userId} {
        allow read: if isSignedIn();
        allow write: if isAuthor(userId);
      }

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    // --- 3. CHATS COLLECTION ---
    match /chats/{chatId} {
      // READ & UPDATE: Check EXISTING data (resource.data)
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // CREATE: Check NEW data (request.resource.data)
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;

      // Messages Subcollection
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // --- 4. RUN NEWS COLLECTION ---
    match /run_news/{newsId} {
      allow read: if isSignedIn();
    }

    // --- 5. INSTITUTIONAL COLLECTIONS ---
    match /run_our_history/{docId} {
      allow read: if isSignedIn();
    }
    match /run_governance/{docId} {
      allow read: if isSignedIn();
    }
    match /run_motto_logo_anthem/{docId} {
      allow read: if isSignedIn();
    }
    match /run_vision_mission/{docId} {
      allow read: if isSignedIn();
    }

    // --- 5. NOTIFICATIONS COLLECTION ---
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }
  }
}